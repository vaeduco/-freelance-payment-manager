# Supabase project credentials.
# Copy this file to .env.local and fill in the values from your Supabase dashboard
# (Project Settings -> API). Only the URL and the ANON (public) key belong in a
# frontend app. NEVER put the service_role key in NEXT_PUBLIC_* variables.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
